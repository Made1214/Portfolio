---
/**
 * Projects.astro — Sección de proyectos destacados.
 * Renderiza una grilla de tarjetas (cards) con los proyectos.
 * Cada tarjeta muestra: imagen/fondo degradado, badges de tecnologías usadas,
 * título, descripción y botones de Demo / Código fuente.
 * Los proyectos se definen en el array 'projects' del frontmatter.
 */
import Badge from "../components/badge.astro";

const projects = [
  {
    title: "Dashboard Analytics",
    description:
      "Plataforma de análisis de datos con visualizaciones interactivas en tiempo real y reportes personalizables.",
    techs: ["React", "TypeScript", "D3.js"],
    github: "https://github.com/",
    demo: "#",
    bgStyle: "background: linear-gradient(135deg, #7c3aed, #4338ca)",
  },
  {
    title: "E-Commerce App",
    description:
      "Aplicación de comercio electrónico con carrito de compras, pagos integrados y panel de administración.",
    techs: ["Next.js", "Stripe", "Tailwind"],
    github: "https://github.com/",
    demo: "#",
    bgStyle: "background: linear-gradient(135deg, #c084fc, #9333ea)",
  },
  {
    title: "Task Manager",
    description:
      "App de gestión de tareas con autenticación, drag & drop y notificaciones en tiempo real.",
    techs: ["Vue.js", "Node.js", "MongoDB"],
    github: "https://github.com/",
    demo: "#",
    bgStyle: "background: linear-gradient(135deg, #a855f7, #6d28d9)",
  },
];
---

<section id="proyectos" class="py-16 md:py-24 bg-gray-100/50 dark:bg-gray-900/50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-12">
      <div>
        <p class="text-purple-600 dark:text-purple-400 font-semibold text-sm uppercase tracking-widest mb-2">
          Portafolio
        </p>
        <h2 class="text-3xl md:text-4xl font-bold">Proyectos Destacados</h2>
      </div>
      <a
        href="https://github.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-purple-600 dark:text-purple-400 hover:text-purple-700 dark:hover:text-purple-300 font-medium transition-colors"
      >
        Ver todo en GitHub
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>

    <!-- Grilla responsive: 1 col (mobile), 2 col (tablet), 3 col (desktop) -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project) => (
        <div class="bg-white dark:bg-gray-900 rounded-2xl overflow-hidden border border-gray-100 dark:border-gray-800 hover:shadow-lg transition-all duration-300 group">
          <!-- Fondo degradado que simula la imagen del proyecto -->
          <div style={project.bgStyle} class="h-48 flex items-center justify-center">
            <svg class="w-16 h-16 text-white/30 group-hover:text-white/50 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
            </svg>
          </div>

          <div class="p-6">
            <!-- Etiquetas de tecnologías usadas en el proyecto -->
            <div class="flex flex-wrap gap-2 mb-3">
              {project.techs.map((tech) => (
                <Badge variant="tech">{tech}</Badge>
              ))}
            </div>

            <h3 class="text-2xl font-bold mb-2">{project.title}</h3>
            <p class="text-gray-600 dark:text-gray-400 text-lg mb-4 leading-relaxed">
              {project.description}
            </p>

            <!-- Botones de Live Demo y código fuente -->
            <div class="flex gap-3">
              <a
                href={project.demo}
                class="px-5 py-2.5 bg-purple-600 hover:bg-purple-700 text-white text-base font-medium rounded-full transition-colors"
              >
                Live Demo
              </a>
              <a
                href={project.github}
                target="_blank"
                rel="noopener noreferrer"
                class="px-5 py-2.5 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:border-purple-500 hover:text-purple-600 dark:hover:text-purple-400 text-base font-medium rounded-full transition-colors"
              >
                View Code
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
